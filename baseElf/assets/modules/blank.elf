function createBlank() {
    %obj = new ScriptObject() {
        class = "Blank";
    };

    return %obj;
}
//----------------------------------------------------------------------
function Blank::onAdd(%this) {
    ClearBackground(SLATEGRAY); //only set once
    return true;
}
//----------------------------------------------------------------------
function Blank::OnRemove(%this) {
}
//----------------------------------------------------------------------
function Blank::OnUpdate(%this, %dt) {
}
//----------------------------------------------------------------------
function Blank::Render(%this) {
}
