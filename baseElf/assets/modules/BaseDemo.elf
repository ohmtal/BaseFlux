    for (%i = 0; %i < %cnt; %i++) {
        %logo = LogoList.getObject(%i);
        %logo.moveLinear();
        if ($ticker % 2 == 0) {
            if (%logo.x <= 30.0 ) { %logo.VeloX *= -1.0; %logo.x = 30.01;}
            else if ( %logo.x >= %bx) { %logo.VeloX *= -1.0; %logo.x = %bx - 0.01;}
            if (%logo.y <= 30.0)  { %logo.VeloY *= -1.0; %logo.y = 30.01;}
            else if ( %logo.y >= %by) { %logo.VeloY *= -1.0; %logo.y = %by - 0.01; }
