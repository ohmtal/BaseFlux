//----------------------------------------------------------------------
function BaseDemo::addLogo(%this,%x,%y) {

    %logo = new GameObject() {
        x = %x;
        y = %y;
        veloX = getRandom(-250,250);
        veloY = getRandom(-250,250);
        color = getRandom(0,255) SPC getRandom(0,255) SPC getRandom(0,255) SPC getRandom(32,255);
    };
    LogoList.add(%logo);
    echo("added logo:" SPC %logo);
}
//----------------------------------------------------------------------
/*
 * onInputEvent - basic keyboard and mouse supported
 */
function BaseDemo::onInputEvent( %this, %deviceString, %actionString, %mouseX, %mouseY, %keyValue ) {
    // echo("onInputEvent Device:" SPC %deviceString SPC "action:" SPC %actionString SPC "mx/my:" SPC %mouseX SPC %mouseY SPC "DOWN:" SPC %keyValue);
/*    if (%deviceString $= "keyboard") {
        invaderGame.Keys[%actionString] = %keyValue;
        if (!%keyValue) {//keyup
            if (%actionString $= "escape") {
                quit();
            }
        }
    }
    else */
    if (%deviceString $= "mouse" ) {
        if (%keyValue == 1) {
            // echo("MOUSE! val:" SPC %keyValue SPC %actionString);
            if (%actionString $= "button3") {
                for (%i = 0; %i < LOGO_SPAWN_RATE; %i++) %this.addLogo(%mouseX, %mouseY);
            }
        }
    }
}

